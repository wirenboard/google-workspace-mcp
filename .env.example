# Google Workspace MCP — remote multi-user (OAuth 2.1) deployment.
# Copy to .env and fill in real values:  cp .env.example .env   (or: make env)
# .env is gitignored; docker compose reads these for ${...} substitution.

# --- Google OAuth "Internal" app (Google Cloud Console) ----------------------
# One "Web application" client for the whole organization (User type: Internal).
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# --- Public host -------------------------------------------------------------
# Public HTTPS domain of this server (host only, no scheme). Drives both the
# external URL (https://<domain>) and the Traefik router. The OAuth client's
# Authorized redirect URI must be exactly  https://<domain>/oauth2callback
WORKSPACE_DOMAIN=mcp.example.com

# --- Image (optional) --------------------------------------------------------
# Full ghcr.io image path. MUST equal your GitHub repo path, because CI pushes
# to ghcr.io/<owner>/<repo>. Uncomment and set if your repo is not named as the
# default baked into docker-compose.yml. watchtower auto-updates the running tag.
# IMAGE=ghcr.io/wirenboard/google-workspace-mcp:latest
